# 会议室离线部署环境变量模板
# 首次部署前，请至少修改 APP_ROOT、POSTGRES_PASSWORD、CORS_ORIGINS。

APP_ROOT=/opt/paperless_meeting
APP_VERSION=offline-latest

TZ=Asia/Shanghai
FRONTEND_PORT=5000
WORKERS=4

POSTGRES_USER=paperless
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=paperless_meeting

CORS_ORIGINS=http://127.0.0.1:5000,http://localhost:5000

POSTGRES_IMAGE=postgres:15-alpine
REDIS_IMAGE=redis:7-alpine
BACKEND_IMAGE=paperless-meeting/backend:offline-latest
FRONTEND_IMAGE=paperless-meeting/frontend:offline-latest
