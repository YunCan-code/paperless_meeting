<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#0F172A"
                android:startColor="#0EA5E9"
                android:centerColor="#1D4ED8" />
        </shape>
    </item>

    <item
        android:gravity="top|end"
        android:top="48dp"
        android:right="56dp">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <solid android:color="#1FFFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="bottom|start"
        android:bottom="64dp"
        android:left="72dp">
        <shape android:shape="oval">
            <size android:width="164dp" android:height="164dp" />
            <solid android:color="#16FFFFFF" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:left="120dp"
        android:right="120dp"
        android:top="120dp"
        android:bottom="120dp">
        <shape android:shape="rectangle">
            <corners android:radius="36dp" />
            <solid android:color="#18FFFFFF" />
        </shape>
    </item>
</layer-list>
